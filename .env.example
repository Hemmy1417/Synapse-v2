# ── Synapse Environment Variables ─────────────────────────────────
# Copy this file to .env.local for local development.
# Add ALL of these to your Vercel project in:
# Vercel Dashboard → Your Project → Settings → Environment Variables

# ── AI Agents (Required) ───────────────────────────────────────────
# Get from: https://console.groq.com → API Keys
GROQ_API_KEY=GROQ_API_KEY=your_groq_api_key_here

# ── Firebase (Required for persistent storage) ─────────────────────
# Get from: Firebase Console → Project Settings → Your Apps → Web App
# https://console.firebase.google.com
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyB5ZT9_-t6FWDTo276b1YVKT4M8n6FZcKM
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=Synapse-v2-89ce9.firebaseapp.com
NEXT_PUBLIC_FIREBASE_DATABASEURL=https://synapse-v2-89ce9-default-rtdb.firebaseio.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=Synapse-v2-89ce9
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=synapse-v2-89ce9.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=644419126825
NEXT_PUBLIC_FIREBASE_APP_ID=1:644419126825:web:c6b2b5d8092d3ed4f73e38

# ── GenLayer (Optional — app works without these) ──────────────────
# Get contract address after deploying SynapseConsensus.py
NEXT_PUBLIC_SYNAPSE_CONTRACT_ADDRESS=0x2153db13395123DB8eBb6651cefc79cA30cd0663
NEXT_PUBLIC_GENLAYER_RPC=https://zksync-os-testnet-genlayer.zksync.dev
